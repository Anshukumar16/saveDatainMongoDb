<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>hello this is ejs data show of mongodb</h1>
    <table border="1">
        <tr>
            <th>Name</th>
            <th>Age</th>
            <th>email</th>
        </tr>
        <% students.forEach(student => { %>
            <tr>
                <td><%= student.name %></td>
                <td><%= student.age %></td>
                <td><%= student.email %></td>
            </tr>
        <% }) %>
    </table>
</body>
</html>